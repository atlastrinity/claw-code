//
//  TerminalView.swift
//  ClawControllerFeature
//
//  Terminal view for displaying command output
//

import SwiftUI

public struct TerminalView: View {
    @Environment(RemoteService.self) private var remoteService
    
    @State private var commandHistory: [CommandHistoryEntry] = []
    @State private var searchText: String = ""
    @State private var showAllLogs: Bool = false
    
    private let maxHistory: Int = 100
    
    public init() {}
    
    public var body: some View {
        ScrollView {
            VStack(alignment: .leading, spacing: 4) {
                // Filter bar
                HStack {
                    TextField("Search commands...", text: $searchText)
                        .textFieldStyle(.roundedBorder)
                        .padding(.horizontal)
                        .padding(.vertical, 8)
                    
                    Spacer()
                    
                    Button(action: clearHistory) {
                        Label("Clear", systemImage: "trash")
                    }
                    .buttonStyle(.bordered)
                }
                .padding(.horizontal)
                .padding(.vertical, 8)
                
                Divider()
                
                // Command history
                ForEach(filteredHistory, id: \.id) { entry in
                    TerminalCommandRow(entry: entry)
                }
                
                if filteredHistory.isEmpty {
                    EmptyStateView()
                }
            }
            .padding(.vertical)
        }
        .background(HackerTheme.backgroundColor)
        .cornerRadius(8)
        .overlay(
            RoundedRectangle(cornerRadius: 8)
                .stroke(HackerTheme.accentColor, lineWidth: 1)
        )
    }
    
    // MARK: - Computed Properties
    
    private var filteredHistory: [CommandHistoryEntry] {
        if searchText.isEmpty {
            return Array(commandHistory.prefix(maxHistory))
        } else {
            return commandHistory.filter { entry in
                entry.command.localizedCaseInsensitiveContains(searchText) ||
                (entry.result?.message ?? "").localizedCaseInsensitiveContains(searchText)
            }
        }
    }
    
    // MARK: - Actions
    
    private func clearHistory() {
        commandHistory.removeAll()
    }
    
    private func copyCommand(_ command: String) {
        #if os(iOS)
        UIPasteboard.general.string = command
        #else
        NSPasteboard.general.clearContents()
        NSPasteboard.general.setString(command, forType: .string)
        #endif
    }
}

// MARK: - Command Row

private struct TerminalCommandRow: View {
    let entry: CommandHistoryEntry
    
    var body: some View {
        HStack(alignment: .top, spacing: 8) {
            // Status indicator
            Circle()
                .fill(statusColor)
                .frame(width: 8, height: 8)
            
            // Command
            VStack(alignment: .leading, spacing: 4) {
                Text("> \(entry.command)")
                    .font(.system(.body, design: .monospaced))
                    .foregroundColor(HackerTheme.textColor)
                
                if let result = entry.result {
                    Text(result.message)
                        .font(.system(.caption, design: .monospaced))
                        .foregroundColor(HackerTheme.secondaryTextColor)

                    if let data = result.data, !data.isEmpty {
                        VStack(alignment: .leading, spacing: 2) {
                            ForEach(Array(data.keys), id: \.self) { key in
                                HStack {
                                    Text(key)
                                        .font(.system(.caption2, design: .monospaced))
                                        .foregroundColor(HackerTheme.accentColor)

                                    Text(": \(data[key] ?? "")")
                                        .font(.system(.caption2, design: .monospaced))
                                        .foregroundColor(HackerTheme.textColor)
                                }
                            }
                        }
                    }
                }
                
                // Timestamp
                Text(entry.timestamp)
                    .font(.system(.caption2, design: .monospaced))
                    .foregroundColor(HackerTheme.secondaryTextColor)
            }
            
            Spacer()
            
            // Copy button
            Button(action: {
                UIPasteboard.general.string = entry.command
            }) {
                Image(systemName: "doc.on.doc")
                    .font(.system(.caption))
                    .foregroundColor(HackerTheme.secondaryTextColor)
            }
            .buttonStyle(.plain)
        }
        .padding(.horizontal, 12)
        .padding(.vertical, 8)
        .background(
            RoundedRectangle(cornerRadius: 4)
                .fill(entry.status == .success ? 
                      Color.green.opacity(0.1) : 
                      Color.orange.opacity(0.1))
        )
    }
    
    private var statusColor: Color {
        switch entry.status {
        case .success:
            return .green
        case .failed:
            return .red
        case .pending, .executing:
            return .orange
        case .cancelled:
            return .gray
        }
    }
    
    private func formatTimestamp(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.dateFormat = "HH:mm:ss.SSS"
        return formatter.string(from: date)
    }
}

// MARK: - Empty State

private struct EmptyStateView: View {
    var body: some View {
        VStack(spacing: 16) {
            Image(systemName: "terminal")
                .font(.system(.largeTitle))
                .foregroundColor(HackerTheme.secondaryTextColor)
            
            Text("No commands yet")
                .font(.headline)
                .foregroundColor(HackerTheme.textColor)
            
            Text("Commands will appear here as you execute them")
                .font(.subheadline)
                .foregroundColor(HackerTheme.secondaryTextColor)
        }
        .frame(maxWidth: .infinity, maxHeight: .infinity)
    }
}

