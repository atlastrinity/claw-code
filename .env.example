RAG_BASE_URL="http://127.0.0.1:8787"
CLAW_READ_FILE_MAX_LINES="800"

# RAG Chunking
CLAW_RAG_CHUNK_CHARS="2000"
CLAW_RAG_CHUNK_OVERLAP="400"
